# ============================================
# Environment Variables - Client (Frontend)
# ============================================

# API Backend URL
VITE_API_BASE_URL=http://localhost:3001/api

# Aplikasi Info
VITE_APP_NAME="Sistem Informasi Zakat"
VITE_APP_VERSION=1.0.0

# Konfigurasi Masjid (default values, bisa diubah oleh Admin)
VITE_NAMA_MASJID="Masjid Al-Ikhlas"
VITE_ALAMAT_MASJID="Jl. Masjid Raya No. 1"
VITE_HARGA_BERAS_DEFAULT=15000
VITE_NISAB_MAL_DEFAULT=85000000

# Konfigurasi Debug
VITE_ENABLE_DEBUG=false
